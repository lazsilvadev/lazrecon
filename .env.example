# -------------------------------------------------------------------------------
# LazRecon - Environment Variables Configuration (Template)
# -------------------------------------------------------------------------------
# Rename this file to '.env' and fill in the values to enable extended features.
# -------------------------------------------------------------------------------

# --- GUI & App Settings ---
# Default language (options: en, pt-br)
APP_LANGUAGE=en
# Theme mode (options: dark, light)
APP_THEME=dark

# --- Future API Integrations (Optional) ---
# Add your API keys below to enable external lookups during reconnaissance.
# SHODAN_API_KEY=your_shodan_key_here
# VIRUSTOTAL_API_KEY=your_vt_key_here

# --- Network Settings ---
# Increase timeout (in seconds) for slower targets
SCAN_TIMEOUT=10
# Default User-Agent rotation (true/false)
ROTATE_USER_AGENTS=true

# NOTE: Environment variable support is currently in development and will be enabled in future versions.
